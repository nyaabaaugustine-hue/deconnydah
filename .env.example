# Neon PostgreSQL Database
# Get your connection string from: https://console.neon.tech
# Format: postgresql://username:password@ep-xxxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://username:password@ep-xxxxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# App Configuration
VITE_APP_NAME=Degoony Evergreen Fleet
VITE_APP_VERSION=1.0.0

# Backend server
PORT=3001
# Comma-separated list of frontend origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:5173

# Cloudinary (for image uploads)
VITE_CLOUDINARY_CLOUD_NAME=
