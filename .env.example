# =============================================================================
# Degoony Fleet ERP - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running locally.
# For Vercel deployment, set these in the project dashboard -> Settings -> Env Vars.

# -- Required ------------------------------------------------------------------
# Neon PostgreSQL connection string (pooled mode recommended for Vercel)
# Get yours from: https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# -- Application ---------------------------------------------------------------
ADMIN_PASSWORD=admin  # Optional: override default admin password
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# -- Cloudinary (optional - needed for image uploads) --------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# -- MinIO / S3-compatible storage (optional - needed for document uploads) ----
# Local dev: docker compose up -d
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_REGION=us-east-1
MINIO_MEDIA_BUCKET=fleet-media
MINIO_DOCUMENTS_BUCKET=fleet-documents
MINIO_PUBLIC_URL=http://localhost:9000

# -- Database pool tuning (optional - defaults are fine for most deployments) ---
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=10000
