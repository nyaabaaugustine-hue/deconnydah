[TEMPLATE]
# ==============================================================================
# Neon PostgreSQL Database -- Production Configuration
# ==============================================================================

# -- Primary connection string ------------------------------------------------
# Get your connection string from: https://console.neon.tech
# For production, use the pooled connection (-pooler suffix) for best performance.
# For direct (non-pooled) connection, remove the -pooler suffix.
DATABASE_URL=postgresql://neondb_owner:npg_cR7yZWlrqX8N@ep-twilight-salad-avhzsqqv-pooler.c-11.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# -- Pool Tuning --------------------------------------------------------------
# Max connections in the pool. Neon free/launch plan limits ~20 connections.
DB_POOL_MAX=20
# Close idle connections after N ms (default: 30s)
DB_POOL_IDLE_TIMEOUT=30000
# Wait N ms for a connection before timing out (default: 10s)
DB_POOL_CONNECTION_TIMEOUT=10000

# -- Read Replica (optional, for analytics) ----------------------------------
# READ_REPLICA_URL=postgresql://username:password@ep-xxxxx-read-replica.region.aws.neon.tech/neondb?sslmode=require

# ==============================================================================
# Backend Server
# ==============================================================================
PORT=3001
NODE_ENV=development
# In development the server also trusts any http://localhost:<port> origin
# automatically (see server/index.ts), so Vite hopping to 5174/5175 when 5173
# is busy won't break login. This list only matters strictly in production —
# set it to your real deployed frontend URL(s), comma-separated.
ALLOWED_ORIGINS=http://localhost:5173

# ==============================================================================
# MinIO (S3-compatible object storage — photos, avatars, documents, receipts)
# ==============================================================================
# Local dev: `docker compose up -d` starts MinIO + creates both buckets automatically.
# API on :9000, console (bucket browser/UI) on :9001 -> http://localhost:9001
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_REGION=us-east-1
# Buckets: media = public-read (photos/avatars), documents = private (receipts/reports/docs)
MINIO_MEDIA_BUCKET=fleet-media
MINIO_DOCUMENTS_BUCKET=fleet-documents
# Public-facing host used to build direct photo/avatar URLs. In production this
# is your MinIO server's real public hostname (e.g. https://storage.yourdomain.com)
# — only needs to be set separately from MINIO_ENDPOINT if they differ (e.g.
# behind a reverse proxy with a different external hostname/port).
MINIO_PUBLIC_URL=http://localhost:9000
